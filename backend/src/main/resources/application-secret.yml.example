# 로컬 비밀값 — 이 파일을 application-secret.yml 로 복사 후 실제 값을 채운다.
# 활성화: SPRING_PROFILES_ACTIVE=local,oauth,secret
#
# 절대 commit 하지 말 것 — application-secret.yml 은 .gitignore 처리됨.
spring:
  security:
    oauth2:
      client:
        registration:
          github:
            clientId: PASTE_GITHUB_CLIENT_ID_HERE
            clientSecret: PASTE_GITHUB_CLIENT_SECRET_HERE

# (선택) JWT 비밀키를 로컬에서 고정하고 싶을 때만:
# security:
#   jwt:
#     secret: any-long-random-string-at-least-32-bytes-please
